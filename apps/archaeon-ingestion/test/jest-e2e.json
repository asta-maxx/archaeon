{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(?:.pnpm/)?(octokit|@octokit|universal-user-agent|universal-github-app-jwt|before-after-hook|is-plain-object))"
  ]
}
