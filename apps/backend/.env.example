# Django Settings
DJANGO_SECRET_KEY=django-insecure-replace-this-in-production-with-something-secure
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database Configuration
DATABASE_NAME=archaeon
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis Cache and Broker Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Celery Configurations
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Authentication Settings
JWT_SECRET=jwt-secret-replace-this-in-production-with-something-secure

# GitHub OAuth Configurations (Authentication Module Phase 2)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# AI & Memory API Keys
OPENAI_API_KEY=your_openai_api_key
COGNEE_API_KEY=your_cognee_api_key
COGNEE_PROJECT_ID=your_cognee_project_id

# Graph Database Settings (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Security & Services Keys
INTERNAL_API_KEY=your_internal_api_key
LOG_LEVEL=INFO
